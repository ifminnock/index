    <div class="viz-area" id="viz-area">
      <div class="empty-state" id="empty-state">
        <div class="icon">🔩</div>
        <div>Configure components at left<br>and click <strong>Update Drawing</strong></div>
      </div>
      <div class="canvas-wrapper" id="canvas-wrapper" style="display:none">
        <canvas id="wellCanvas"></canvas>
        <div class="canvas-label" id="canvas-mode-label">Cross Section</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;align-self:flex-start;">
        <div class="legend"        id="legend-box"  style="display:none"></div>
        <div class="summary-table" id="summary-box" style="display:none"></div>
        <div id="flags-box" style="display:flex;flex-direction:column;gap:4px;max-width:260px;"></div>
      </div>
    </div>
    <div class="notes-area">
      <textarea id="well-notes" placeholder="Well notes / boring log remarks..."></textarea>
    </div>
  </div>

</div><!-- end workspace -->

<script>
// ── STATE ────────────────────────────────────────────────────────────────────
let currentMode = 'piezometer';
let soilLayers  = [];
let soilLayerCount = 0;

const SOIL_COLORS = ['#8B6914','#C4A262','#9E8060','#6B8C42','#4A7CA5','#A05050','#7A9E7A','#B8A878','#5C7A8A','#8C7050'];
const SOIL_TYPES  = ['Gravel','Sand','Silt','Clay','Peat','Fill','Bedrock'];

// ── UI HELPERS ────────────────────────────────────────────────────────────────
function toggleSection(id) {
  const body = document.getElementById('sec-' + id);
  const arrow = document.getElementById('arrow-' + id);
  const hidden = body.style.display === 'none';
  body.style.display = hidden ? '' : 'none';
  arrow.textContent = hidden ? '▼' : '▶';
}

function setMode(mode) {
  currentMode = mode;
  ['piezometer','perc','monitoring'].forEach(m =>
    document.getElementById('btn-' + m).classList.toggle('active', m === mode)
  );
  draw();
}

function toggleComp(id) {
  const chk    = document.getElementById('chk-' + id);
  const inputs = document.getElementById('inputs-' + id);
  const row    = document.getElementById('row-' + id);
  if (!chk || !inputs) return;
  const on = chk.checked;
  inputs.classList.toggle('visible', on);
  if (row) row.classList.toggle('active', on);
  draw();
}

function isOn(id) { const el = document.getElementById('chk-' + id); return el ? el.checked : false; }
function val(id)  { const el = document.getElementById(id); return el ? (parseFloat(el.value) || 0) : 0; }
function sel(id)  { const el = document.getElementById(id); return el ? el.value : ''; }

// ── SOIL LAYERS ───────────────────────────────────────────────────────────────
function addSoilLayer() {
  soilLayerCount++;
  const id = soilLayerCount;
  const defaultTop = soilLayers.length > 0 ? soilLayers[soilLayers.length-1].bot : 0;
  const defaultBot = Math.min(defaultTop + 5, val('borehole-depth'));
  soilLayers.push({ id, top: defaultTop, bot: defaultBot, type: 'Sand', color: SOIL_COLORS[soilLayers.length % SOIL_COLORS.length] });
  renderSoilLayers();
  draw();
}

function removeSoilLayer(id) {
  soilLayers = soilLayers.filter(l => l.id !== id);
  renderSoilLayers(); draw();
}

function renderSoilLayers() {
  const c = document.getElementById('soil-layers-container');
  c.innerHTML = '';
  soilLayers.forEach(layer => {
    const div = document.createElement('div');
    div.className = 'component-row active';
    div.style.marginBottom = '10px';
    div.innerHTML = `
      <div style="flex:1">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
          <span class="component-label" style="font-size:12px;">Layer ${layer.id}</span>
          <button onclick="removeSoilLayer(${layer.id})" style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:14px;">✕</button>
        </div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <div class="input-group" style="min-width:70px">
            <label>Top (ft)</label>
            <input type="number" value="${layer.top}" min="0" max="299" step="0.5" onchange="updateLayer(${layer.id},'top',this.value)">
          </div>
          <div class="input-group" style="min-width:70px">
            <label>Bot (ft)</label>
            <input type="number" value="${layer.bot}" min="0.5" max="300" step="0.5" onchange="updateLayer(${layer.id},'bot',this.value)">
          </div>
          <div class="input-group" style="min-width:100px">
            <label>Dominant Soil</label>
            <select onchange="updateLayer(${layer.id},'type',this.value)">
              ${SOIL_TYPES.map(t => `<option value="${t}"${t===layer.type?' selected':''}>${t}</option>`).join('')}
            </select>
          </div>
        </div>
        <div style="margin-top:6px;">
          <label style="font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;">Color</label>
          <div class="color-row">
            ${SOIL_COLORS.map(c2 => `<div class="color-swatch${c2===layer.color?' selected':''}" style="background:${c2}" onclick="updateLayer(${layer.id},'color','${c2}');renderSoilLayers();"></div>`).join('')}
          </div>
        </div>
      </div>`;
    c.appendChild(div);
  });
}

function updateLayer(id, field, value) {
  const layer = soilLayers.find(l => l.id === id);
  if (!layer) return;
  layer[field] = (field==='top'||field==='bot') ? parseFloat(value) : value;
  draw();
}

// ── DRAWING ENGINE ────────────────────────────────────────────────────────────
function draw() {
  const zoom       = parseFloat(document.getElementById('zoom-slider').value);
  document.getElementById('zoom-label').textContent = zoom.toFixed(1) + '×';

  const totalDepth = val('borehole-depth') || 20;
  const boreDia    = val('borehole-dia')   || 7;
  const stickUp    = isOn('stick') ? val('stick-height') : 0;
  const pxPerFt    = 24; // base scale; zoom applied via canvas dimensions

  // Canvas layout: fixed title zone + stick-up zone + depth zone
  const TITLE_H   = 60;  // px above grade (title block) — always enough clearance
  const stickH    = stickUp * pxPerFt;
  const aboveGrade = TITLE_H + stickH;
  const belowGrade = totalDepth * pxPerFt + 30;
  const totalH     = aboveGrade + belowGrade;
  const totalW     = 320;

  const canvas = document.getElementById('wellCanvas');
  canvas.width  = Math.round(totalW * zoom);
  canvas.height = Math.round(totalH * zoom);
  const ctx = canvas.getContext('2d');
  ctx.scale(zoom, zoom);  // draw everything at base px, canvas scales it

  const marginL = 58;
  const marginR = 18;
  const drawW   = totalW - marginL - marginR;
  const surfaceY = aboveGrade; // y of ground surface in base px

  const dy = d => surfaceY + d * pxPerFt;
  const boreholeR = (boreDia / 2) * (drawW / (boreDia + 10));
  const inToPx    = inches => inches * (boreholeR / (boreDia / 2));
  const cx        = marginL + drawW / 2;

  // Clear
  ctx.fillStyle = '#1C2730';
  ctx.fillRect(0, 0, totalW, totalH);

  // ── SOIL PROFILE ──────────────────────────────────────────────────────────
  soilLayers.forEach(layer => {
    const yT = dy(layer.top);
    const yB = Math.min(dy(layer.bot), dy(totalDepth));
    if (yB <= yT) return;
    ctx.fillStyle = layer.color + '44';
    ctx.fillRect(0, yT, cx - boreholeR, yB - yT);
    ctx.fillRect(cx + boreholeR, yT, totalW - (cx + boreholeR), yB - yT);
    drawSoilHatch(ctx, layer.type, layer.color, 0, yT, cx - boreholeR, yB - yT);
    drawSoilHatch(ctx, layer.type, layer.color, cx + boreholeR, yT, totalW - (cx + boreholeR), yB - yT);
    ctx.fillStyle = layer.color;
    ctx.font = '9px Courier New';
    ctx.fillText(layer.type.substring(0,4), 3, (yT+yB)/2 + 3);
  });

  // ── ANNULAR FILLS ─────────────────────────────────────────────────────────
  if (isOn('cuttings')) {
    const yT = dy(val('cut-top')), yB = dy(val('cut-bot'));
    if (yB > yT) {
      ctx.fillStyle = '#7A604088';
      ctx.fillRect(cx - boreholeR, yT, boreholeR*2, yB - yT);
      drawDots(ctx, '#AA8855', cx - boreholeR, yT, boreholeR*2, yB - yT);
      lbl(ctx, 'CUTTINGS', cx + boreholeR + 4, (yT+yB)/2+3, '#AA8855');
    }
  }

  if (isOn('filterpack')) {
    const yT = dy(val('fp-top')), yB = dy(val('fp-bot'));
    if (yB > yT) {
      ctx.fillStyle = '#C4A26270';
      ctx.fillRect(cx - boreholeR, yT, boreholeR*2, yB - yT);
      drawGravel(ctx, cx - boreholeR, yT, boreholeR*2, yB - yT);
      lbl(ctx, 'GRAVEL', cx + boreholeR + 4, (yT+yB)/2+3, '#E8B870');
      const matTxt = {'half-three-quarter':'½–¾"', pea:'Pea', sand:'C. Sand', chips:'Chips', natural:'Natural'}[sel('fp-mat')]||'';
      lbl(ctx, matTxt, cx + boreholeR + 4, (yT+yB)/2+13, '#9AAABB');
    }
  }

  if (isOn('bentonite')) {
    const yT = dy(val('bent-top')), yB = dy(val('bent-bot'));
    if (yB > yT) {
      ctx.fillStyle = '#2F5030BB';
      ctx.fillRect(cx - boreholeR, yT, boreholeR*2, yB - yT);
      drawHatch45(ctx, '#3A8A3A', cx - boreholeR, yT, boreholeR*2, yB - yT);
      lbl(ctx, 'BENTONITE', cx + boreholeR + 4, (yT+yB)/2+3, '#5CBF5C');
      lbl(ctx, {'chips':'⅜" Chips', pellets:'Pellets', granular:'Granular', slurry:'Slurry'}[sel('bent-form')]||'', cx + boreholeR + 4, (yT+yB)/2+13, '#9AAABB');
    }
  }

  if (isOn('grout')) {
    const yT = dy(val('grout-top')), yB = dy(val('grout-bot'));
    if (yB > yT) {
      ctx.fillStyle = '#888888AA';
      ctx.fillRect(cx - boreholeR, yT, boreholeR*2, yB - yT);
      drawHatch90(ctx, '#AAAAAA', cx - boreholeR, yT, boreholeR*2, yB - yT);
      lbl(ctx, 'GROUT', cx + boreholeR + 4, (yT+yB)/2+3, '#BBBBBB');
    }
  }

  // ── BOREHOLE WALLS ────────────────────────────────────────────────────────
  ctx.save();
  ctx.strokeStyle = '#6A7A8A'; ctx.lineWidth = 1; ctx.setLineDash([4,3]);
  ctx.beginPath();
  ctx.moveTo(cx - boreholeR, surfaceY); ctx.lineTo(cx - boreholeR, dy(totalDepth));
  ctx.moveTo(cx + boreholeR, surfaceY); ctx.lineTo(cx + boreholeR, dy(totalDepth));
  ctx.stroke(); ctx.setLineDash([]);
  ctx.strokeStyle = '#6A7A8A'; ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(cx - boreholeR, dy(totalDepth)); ctx.lineTo(cx + boreholeR, dy(totalDepth)); ctx.stroke();
  ctx.restore();

  // ── GWL ───────────────────────────────────────────────────────────────────
  if (isOn('gwl')) {
    const gwY = dy(val('gwl-depth'));
    ctx.save(); ctx.strokeStyle = '#4A9FD4'; ctx.lineWidth = 1.5; ctx.setLineDash([6,3]);
    ctx.beginPath(); ctx.moveTo(0, gwY); ctx.lineTo(totalW, gwY); ctx.stroke();
    ctx.setLineDash([]); ctx.restore();
    ctx.fillStyle = '#4A9FD4'; ctx.font = 'bold 9px Courier New';
    ctx.fillText('▼ GWL  ' + val('gwl-depth') + 'ft', 3, gwY - 3);
    ctx.fillStyle = '#4A9FD418';
    ctx.fillRect(cx - boreholeR, gwY, boreholeR*2, dy(totalDepth) - gwY);
  }

  // ── CONTROL LINE ──────────────────────────────────────────────────────────
  if (isOn('control')) {
    const ctY = dy(val('control-depth'));
    ctx.save(); ctx.strokeStyle = '#E8EAEC'; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(0, ctY); ctx.lineTo(totalW, ctY); ctx.stroke(); ctx.restore();
    ctx.fillStyle = '#E8EAEC'; ctx.font = 'bold 9px Courier New';
    ctx.fillText('CONTROL', 3, ctY - 3);
  }

  // ── PERC GRAVEL INTERVAL ──────────────────────────────────────────────────
  if (isOn('perc')) {
    const yT = dy(val('perc-top')), yB = dy(val('perc-bot'));
    if (yB > yT) {
      ctx.fillStyle = '#C4A26255';
      ctx.fillRect(cx - boreholeR, yT, boreholeR*2, yB - yT);
      drawGravel(ctx, cx - boreholeR, yT, boreholeR*2, yB - yT);
      ctx.save(); ctx.strokeStyle = '#E8B870'; ctx.lineWidth = 1.5; ctx.setLineDash([3,2]);
      ctx.strokeRect(cx - boreholeR, yT, boreholeR*2, yB - yT);
      ctx.setLineDash([]); ctx.restore();
      lbl(ctx, 'PERC GRAVEL', cx + boreholeR + 4, (yT+yB)/2+3, '#E8B870');
    }
  }

  // ── SCREEN ────────────────────────────────────────────────────────────────
  if (isOn('screen') && isOn('casing')) {
    const casingR = inToPx(val('casing-od') / 2);
    const yT = dy(val('screen-top'));
    const yB = dy(val('screen-top') + val('screen-len'));
    if (yB > yT && casingR > 0) {
      const slotSp = 5, nSlots = Math.floor((yB-yT)/slotSp);
      ctx.save(); ctx.strokeStyle = '#D4651A'; ctx.lineWidth = 1;
      for (let i = 0; i < nSlots; i++) {
        const sy = yT + i*slotSp + slotSp/2;
        ctx.beginPath();
        ctx.moveTo(cx - casingR, sy); ctx.lineTo(cx - casingR - 5, sy);
        ctx.moveTo(cx + casingR, sy); ctx.lineTo(cx + casingR + 5, sy);
        ctx.stroke();
      }
      ctx.lineWidth = 2; ctx.strokeRect(cx - casingR, yT, casingR*2, yB-yT);
      ctx.restore();
      lbl(ctx, 'SCREEN', cx + casingR + 8, (yT+yB)/2+3, '#D4651A');
      lbl(ctx, val('screen-len').toFixed(1)+'ft', cx + casingR + 8, (yT+yB)/2+13, '#9AAABB');
    }
  }

  // ── CASING ────────────────────────────────────────────────────────────────
  if (isOn('casing')) {
    const od = val('casing-od'), wall = val('casing-wall');
    const casingR  = inToPx(od / 2);
    const casingIR = inToPx((od - 2*wall) / 2);
    if (casingR > 0) {
      const matColor = {pvc:'#D0E4F0', abs:'#D4C8A8', other:'#C0C8D0'}[sel('casing-mat')] || '#D0C8B8';
      // Draw casing from surface line down (does not include stick-up yet)
      ctx.fillStyle = matColor + 'CC';
      ctx.fillRect(cx - casingR,  surfaceY, casingR - casingIR, dy(totalDepth) - surfaceY);
      ctx.fillRect(cx + casingIR, surfaceY, casingR - casingIR, dy(totalDepth) - surfaceY);
      ctx.save(); ctx.strokeStyle = '#9AAABB'; ctx.lineWidth = 1.5;
      ctx.strokeRect(cx - casingR, surfaceY, casingR*2, dy(totalDepth) - surfaceY);
      ctx.strokeStyle = '#6A7A8A'; ctx.lineWidth = 0.5;
      ctx.strokeRect(cx - casingIR, surfaceY, casingIR*2, dy(totalDepth) - surfaceY);
      ctx.restore();

      // Stick-up above grade
      if (stickUp > 0) {
        const stickTopY = surfaceY - stickH;
        ctx.fillStyle = matColor + 'CC';
        ctx.fillRect(cx - casingR,  stickTopY, casingR - casingIR, stickH);
        ctx.fillRect(cx + casingIR, stickTopY, casingR - casingIR, stickH);
        ctx.save(); ctx.strokeStyle = '#9AAABB'; ctx.lineWidth = 1.5;
        ctx.strokeRect(cx - casingR, stickTopY, casingR*2, stickH); ctx.restore();
        // Dimension arrow
        const dimX = cx + casingR + 16;
        ctx.save(); ctx.strokeStyle = '#E8EAEC33'; ctx.lineWidth = 0.5; ctx.setLineDash([3,3]);
        ctx.beginPath(); ctx.moveTo(dimX, stickTopY); ctx.lineTo(dimX, surfaceY); ctx.stroke();
        ctx.setLineDash([]); ctx.restore();
        ctx.fillStyle = '#9AAABB'; ctx.font = '9px Courier New';
        ctx.fillText('↕ ' + stickUp.toFixed(1) + 'ft', dimX + 2, (stickTopY + surfaceY)/2 + 3);
      }
    }
  }

  // ── CAP ───────────────────────────────────────────────────────────────────
  if (isOn('cap') && isOn('casing')) {
    const casingR = inToPx(val('casing-od') / 2);
    const capY = stickUp > 0 ? surfaceY - stickH - 5 : surfaceY - 5;
    ctx.fillStyle = '#D4651A';
    ctx.fillRect(cx - casingR - 3, capY, (casingR+3)*2, 5);
    ctx.save(); ctx.strokeStyle = '#FF8040'; ctx.lineWidth = 1;
    ctx.strokeRect(cx - casingR - 3, capY, (casingR+3)*2, 5); ctx.restore();
  }

  // ── VAULT ─────────────────────────────────────────────────────────────────
  if (isOn('vault')) {
    const vR = inToPx(val('vault-od') / 2);
    const vH = val('vault-height') * pxPerFt;
    ctx.fillStyle = '#6A6A7A88';
    ctx.fillRect(cx - vR, surfaceY - vH, vR*2, vH);
    ctx.save(); ctx.strokeStyle = '#9AAABB'; ctx.lineWidth = 2;
    ctx.strokeRect(cx - vR, surfaceY - vH, vR*2, vH); ctx.restore();
  }

  // ── CONCRETE PAD ──────────────────────────────────────────────────────────
  if (isOn('pad')) {
    const thPx = (val('pad-thick') / 12) * pxPerFt;
    const padW = boreholeR * 5;
    ctx.fillStyle = '#888888CC';
    ctx.fillRect(cx - padW/2, surfaceY - thPx, padW, thPx);
    ctx.save(); ctx.strokeStyle = '#AAAAAA'; ctx.lineWidth = 1;
    ctx.strokeRect(cx - padW/2, surfaceY - thPx, padW, thPx); ctx.restore();
  }

  // ── GROUND SURFACE ────────────────────────────────────────────────────────
  ctx.save(); ctx.strokeStyle = '#8B6914'; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(0, surfaceY); ctx.lineTo(totalW, surfaceY); ctx.stroke();
  ctx.strokeStyle = '#8B691455'; ctx.lineWidth = 1;
  for (let x = 0; x < totalW; x += 8) {
    ctx.beginPath(); ctx.moveTo(x, surfaceY); ctx.lineTo(x - 5, surfaceY + 5); ctx.stroke();
  }
  ctx.restore();

  // ── BOREHOLE DIA ANNOTATION ───────────────────────────────────────────────
  ctx.fillStyle = '#9AAABB'; ctx.font = '9px Courier New';
  ctx.fillText('⌀ ' + boreDia + '"', cx - boreholeR - 2, surfaceY + 13);

  // ── DEPTH SCALE ───────────────────────────────────────────────────────────
  ctx.fillStyle = '#9AAABB'; ctx.font = '9px Courier New';
  ctx.save(); ctx.strokeStyle = '#4A6070'; ctx.lineWidth = 0.5;
  const dStep = totalDepth > 50 ? 10 : totalDepth > 20 ? 5 : 2;
  for (let d = 0; d <= totalDepth; d += dStep) {
    const y = dy(d);
    ctx.beginPath(); ctx.moveTo(marginL - 7, y); ctx.lineTo(marginL, y); ctx.stroke();
    ctx.fillText(d + 'ft', 2, y + 3);
  }
  ctx.restore();

  // ── TITLE BLOCK ── placed in the TITLE_H zone, always well above stick-up ──
  const titleY = 14; // fixed at top of canvas — TITLE_H zone is always 60px regardless of stick-up
  const modeLabel = {piezometer:'Piezometer', perc:'Percolation / Infiltration Test', monitoring:'Monitoring Well'}[currentMode] || currentMode;
  ctx.fillStyle = '#E8EAEC'; ctx.font = 'bold 11px Courier New';
  ctx.fillText(modeLabel + ' — Cross Section', marginL, titleY);
  ctx.fillStyle = '#9AAABB'; ctx.font = '9px Courier New';
  ctx.fillText('Depth: ' + totalDepth + 'ft  |  Borehole: ' + boreDia + '"', marginL, titleY + 13);

  // Reset transform
  ctx.setTransform(1,0,0,1,0,0);

  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('canvas-wrapper').style.display = 'flex';
  document.getElementById('canvas-mode-label').textContent = modeLabel + ' — Cross Section';

  buildLegend(); buildSummary(); buildFlags();
}

// ── TEXTURE HELPERS ───────────────────────────────────────────────────────────
function lbl(ctx, text, x, y, color) {
  ctx.fillStyle = color; ctx.font = '9px Courier New'; ctx.fillText(text, x, y);
}

function drawSoilHatch(ctx, type, color, x, y, w, h) {
  if (w <= 0 || h <= 0) return;
  ctx.save(); ctx.beginPath(); ctx.rect(x,y,w,h); ctx.clip();
  ctx.strokeStyle = color + 'AA'; ctx.lineWidth = 0.7;
  const sp = 8;
  if (type === 'Gravel' || type === 'Bedrock') {
    for (let cy2 = y+sp/2; cy2 < y+h; cy2 += sp)
      for (let cx2 = x+sp/2; cx2 < x+w; cx2 += sp) { ctx.beginPath(); ctx.arc(cx2,cy2,2.5,0,Math.PI*2); ctx.stroke(); }
  } else if (type === 'Sand' || type === 'Fill') {
    ctx.fillStyle = color + 'BB';
    for (let cy2 = y+sp*0.4; cy2 < y+h; cy2 += sp*0.8)
      for (let cx2 = x+sp*0.4; cx2 < x+w; cx2 += sp*0.8) { ctx.beginPath(); ctx.arc(cx2,cy2,1,0,Math.PI*2); ctx.fill(); }
  } else if (type === 'Silt' || type === 'Clay') {
    for (let ly = y+sp*0.3; ly < y+h; ly += sp*0.6) { ctx.beginPath(); ctx.moveTo(x,ly); ctx.lineTo(x+w,ly); ctx.stroke(); }
  } else if (type === 'Peat') {
    for (let ly = y+sp/2; ly < y+h; ly += sp) {
      ctx.beginPath();
      for (let lx = x; lx < x+w; lx += 4) ctx.lineTo(lx, ly + Math.sin((lx-x)/3)*2);
      ctx.stroke();
    }
  }
  ctx.restore();
}

function drawGravel(ctx, x, y, w, h) {
  ctx.save(); ctx.beginPath(); ctx.rect(x,y,w,h); ctx.clip();
  ctx.fillStyle = '#C4A262';
  for (let gy = y+3; gy < y+h-3; gy += 7)
    for (let gx = x+3; gx < x+w-3; gx += 7) {
      ctx.beginPath(); ctx.arc(gx+(Math.random()-.5)*3, gy+(Math.random()-.5)*3, 2.5, 0, Math.PI*2); ctx.fill();
    }
  ctx.restore();
}

function drawHatch45(ctx, color, x, y, w, h) {
  ctx.save(); ctx.beginPath(); ctx.rect(x,y,w,h); ctx.clip();
  ctx.strokeStyle = color; ctx.lineWidth = 1;
  for (let i = -h; i < w+h; i += 7) { ctx.beginPath(); ctx.moveTo(x+i,y); ctx.lineTo(x+i+h,y+h); ctx.stroke(); }
  ctx.restore();
}

function drawHatch90(ctx, color, x, y, w, h) {
  ctx.save(); ctx.beginPath(); ctx.rect(x,y,w,h); ctx.clip();
  ctx.strokeStyle = color; ctx.lineWidth = 0.8;
  for (let ly = y; ly < y+h; ly += 6) { ctx.beginPath(); ctx.moveTo(x,ly); ctx.lineTo(x+w,ly); ctx.stroke(); }
  for (let lx = x; lx < x+w; lx += 6) { ctx.beginPath(); ctx.moveTo(lx,y); ctx.lineTo(lx,y+h); ctx.stroke(); }
  ctx.restore();
}

function drawDots(ctx, color, x, y, w, h) {
  ctx.save(); ctx.beginPath(); ctx.rect(x,y,w,h); ctx.clip();
  ctx.fillStyle = color;
  for (let gy = y+4; gy < y+h; gy += 8)
    for (let gx = x+4; gx < x+w; gx += 8) { ctx.beginPath(); ctx.arc(gx,gy,1.5,0,Math.PI*2); ctx.fill(); }
  ctx.restore();
}

// ── LEGEND / SUMMARY / FLAGS ──────────────────────────────────────────────────
function buildLegend() {
  const box = document.getElementById('legend-box');
  const items = [];
  if (isOn('cuttings'))   items.push({color:'#AA8855', label:'Auger Cuttings', sub:'backfill'});
  if (isOn('filterpack')) items.push({color:'#C4A262', label:'Filter/Gravel Pack', sub:sel('fp-mat').replace('half-three-quarter','½–¾"')});
  if (isOn('bentonite'))  items.push({color:'#3A8A3A', label:'Bentonite Seal', sub:sel('bent-form')});
  if (isOn('grout'))      items.push({color:'#888888', label:'Cement/Grout', sub:sel('grout-mix')});
  if (isOn('screen'))     items.push({color:'#D4651A', label:'Screen/Perforations', sub:sel('screen-type')});
  if (isOn('casing'))     items.push({color:'#9AAABB', label:'Casing', sub:sel('casing-mat').toUpperCase()});
  if (isOn('gwl'))        items.push({color:'#4A9FD4', label:'Groundwater Level', sub:val('gwl-depth')+'ft bgs'});
  if (isOn('control'))    items.push({color:'#E8EAEC', label:'Control Point', sub:val('control-depth')+'ft bgs'});
  if (isOn('perc'))       items.push({color:'#E8B870', label:'Perc Gravel Interval', sub:val('perc-top')+'–'+val('perc-bot')+'ft'});
  soilLayers.forEach(l => items.push({color:l.color, label:l.type, sub:l.top+'–'+l.bot+'ft'}));
  if (!items.length) { box.style.display='none'; return; }
  box.innerHTML = '<h3>Legend</h3>' + items.map(i =>
    `<div class="legend-item"><div class="legend-swatch" style="background:${i.color}"></div><span>${i.label}</span><span class="dim">${i.sub}</span></div>`
  ).join('');
  box.style.display = 'block';
}

function buildSummary() {
  const box = document.getElementById('summary-box');
  const ml = {piezometer:'Piezometer', perc:'Perc/Infil. Test', monitoring:'Monitoring Well'}[currentMode]||currentMode;
  const rows = [
    {k:'Type', v:ml},
    {k:'Borehole', v:val('borehole-dia')+'" dia'},
    {k:'Total Depth', v:val('borehole-depth')+' ft bgs'},
  ];
  if (isOn('casing'))  rows.push({k:'Casing OD', v:val('casing-od')+'"  '+sel('casing-mat').toUpperCase()});
  if (isOn('screen'))  rows.push({k:'Screen', v:val('screen-top')+'–'+(val('screen-top')+val('screen-len')).toFixed(1)+' ft'});
  if (isOn('gwl'))     rows.push({k:'GWL', v:val('gwl-depth')+' ft bgs'});
  if (isOn('control')) rows.push({k:'Control Pt', v:val('control-depth')+' ft bgs'});
  if (isOn('stick'))   rows.push({k:'Stick-Up', v:val('stick-height')+' ft'});
  box.innerHTML = '<h3>Well Summary</h3>' + rows.map(r =>
    `<div class="summary-row"><span class="key">${r.k}</span><span class="val">${r.v}</span></div>`
  ).join('');
  box.style.display = 'block';
}

function buildFlags() {
  const box = document.getElementById('flags-box');
  const flags = [];
  const bd = val('borehole-depth'), bdia = val('borehole-dia');
  if (isOn('casing') && val('casing-od') >= bdia)
    flags.push({type:'err', msg:'Casing OD ≥ borehole diameter'});
  if (isOn('screen') && isOn('casing') && (val('screen-top')+val('screen-len')) > bd)
    flags.push({type:'warn', msg:'Screen extends below total depth'});
  if (isOn('filterpack') && isOn('bentonite') && val('fp-bot') > val('bent-top'))
    flags.push({type:'warn', msg:'Filter pack and bentonite may overlap'});
  if (isOn('gwl') && isOn('screen')) {
    const gwl=val('gwl-depth'), st=val('screen-top'), sb=st+val('screen-len');
    if (gwl > sb) flags.push({type:'warn', msg:'GWL below screen — well may be dry'});
    if (gwl <= st) flags.push({type:'ok',  msg:'Screen fully below water table ✓'});
  }
  if (isOn('perc') && val('perc-bot') > bd)
    flags.push({type:'warn', msg:'Perc gravel interval extends below total depth'});
  box.innerHTML = flags.map(f => `<div class="flag ${f.type}">${f.msg}</div>`).join('');
}

// ── EXPORT / RESET ────────────────────────────────────────────────────────────
function exportPNG() {
  const canvas = document.getElementById('wellCanvas');
  const a = document.createElement('a');
  a.download = 'well_geometry_' + currentMode + '.png';
  a.href = canvas.toDataURL('image/png');
  a.click();
}

function resetAll() {
  document.querySelectorAll('input[type="checkbox"]').forEach(c => { c.checked = false; });
  document.querySelectorAll('.component-inputs').forEach(d => d.classList.remove('visible'));
  soilLayers = []; soilLayerCount = 0; renderSoilLayers();
  document.getElementById('empty-state').style.display = 'flex';
  document.getElementById('canvas-wrapper').style.display = 'none';
  document.getElementById('legend-box').style.display = 'none';
  document.getElementById('summary-box').style.display = 'none';
  document.getElementById('flags-box').innerHTML = '';
}

