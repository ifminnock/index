<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Well & Boring Geometry Builder — Alaska Geotechnical Tools</title>
<style>
  :root {
    --bg-page:   #2E3A47;
    --bg-card:   #3A4A5C;
    --bg-deep:   #25323E;
    --accent:    #D4651A;
    --accent2:   #4A6070;
    --text:      #E8EAEC;
    --text-dim:  #9AAABB;
    --green:     #4CAF82;
    --yellow:    #E6B840;
    --red:       #C94040;
    --border:    #4A6070;
    --mono:      'Courier New', Consolas, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg-page); color: var(--text); font-family: var(--mono); font-size: 14px; min-height: 100vh; }

header {
background: var(–bg-deep); border-bottom: 2px solid var(–accent);
padding: 14px 24px; display: flex; align-items: center;
justify-content: space-between; flex-wrap: wrap; gap: 8px; position: relative;
}
header .site-title { color: var(–accent); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; }
header h1 { font-size: 17px; color: var(–text); letter-spacing: .04em; }
header nav a {
color: var(–text-dim); font-size: 11px; text-decoration: none;
border: 1px solid var(–border); padding: 4px 10px; border-radius: 3px; transition: color .15s, border-color .15s;
}
header nav a:hover { color: var(–accent); border-color: var(–accent); }

.workspace { display: grid; grid-template-columns: 360px 1fr; gap: 0; min-height: calc(100vh - 62px); }

.panel-left { background: var(–bg-card); border-right: 1px solid var(–border); overflow-y: auto; }
.panel-section { border-bottom: 1px solid var(–border); }
.panel-section-header {
background: var(–bg-deep); padding: 10px 16px; font-size: 11px; letter-spacing: .1em;
text-transform: uppercase; color: var(–accent); cursor: pointer;
display: flex; justify-content: space-between; align-items: center; user-select: none;
}
.panel-section-header:hover { color: var(–text); }
.panel-section-body { padding: 12px 16px; }

.mode-selector { display: flex; gap: 8px; padding: 12px 16px; background: var(–bg-deep); border-bottom: 1px solid var(–border); }
.mode-btn {
flex: 1; background: var(–bg-card); border: 1px solid var(–border); color: var(–text-dim);
font-family: var(–mono); font-size: 10px; letter-spacing: .06em; text-transform: uppercase;
padding: 8px 4px; cursor: pointer; border-radius: 3px; transition: all .15s; line-height: 1.4; text-align: center;
}
.mode-btn.active { background: var(–accent); border-color: var(–accent); color: #fff; }
.mode-btn:hover:not(.active) { border-color: var(–accent); color: var(–accent); }

.component-row {
display: flex; align-items: flex-start; gap: 10px; margin-bottom: 10px;
padding: 8px 10px; border: 1px solid transparent; border-radius: 4px; transition: border-color .15s, background .15s;
}
.component-row.active { background: rgba(212,101,26,.08); border-color: var(–accent); }
.component-row input[type=“checkbox”] { margin-top: 2px; accent-color: var(–accent); width: 15px; height: 15px; flex-shrink: 0; cursor: pointer; }
.component-label { font-size: 13px; color: var(–text); line-height: 1.3; flex: 1; cursor: pointer; }
.component-label .sub { font-size: 11px; color: var(–text-dim); display: block; margin-top: 2px; }

.component-inputs { display: none; margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(–border); gap: 8px; flex-wrap: wrap; }
.component-inputs.visible { display: flex; }
.input-group { display: flex; flex-direction: column; gap: 3px; min-width: 90px; flex: 1; }
.input-group label { font-size: 10px; color: var(–text-dim); letter-spacing: .06em; text-transform: uppercase; }
.input-group input, .input-group select {
background: var(–bg-deep); border: 1px solid var(–border); color: var(–text);
font-family: var(–mono); font-size: 12px; padding: 5px 8px; border-radius: 3px; width: 100%; transition: border-color .15s;
}
.input-group input:focus, .input-group select:focus { outline: none; border-color: var(–accent); }
.input-group select option { background: var(–bg-deep); }

.color-row { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; margin-top: 4px; }
.color-swatch { width: 22px; height: 22px; border-radius: 3px; border: 2px solid transparent; cursor: pointer; transition: border-color .15s, transform .1s; }
.color-swatch:hover { transform: scale(1.15); }
.color-swatch.selected { border-color: var(–text); }

.btn-primary { background: var(–accent); border: none; color: #fff; font-family: var(–mono); font-size: 12px; letter-spacing: .08em; text-transform: uppercase; padding: 10px 20px; cursor: pointer; border-radius: 3px; width: 100%; margin-top: 8px; transition: background .15s; }
.btn-primary:hover { background: #b8521a; }
.btn-secondary { background: transparent; border: 1px solid var(–border); color: var(–text-dim); font-family: var(–mono); font-size: 11px; letter-spacing: .06em; text-transform: uppercase; padding: 7px 14px; cursor: pointer; border-radius: 3px; transition: all .15s; }
.btn-secondary:hover { border-color: var(–accent); color: var(–accent); }

.panel-right { display: flex; flex-direction: column; overflow: hidden; }
.viz-header { background: var(–bg-deep); border-bottom: 1px solid var(–border); padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
.viz-header span { font-size: 11px; color: var(–text-dim); letter-spacing: .08em; text-transform: uppercase; }
.viz-controls { display: flex; gap: 8px; align-items: center; }
.viz-controls label { font-size: 11px; color: var(–text-dim); }
.viz-controls input[type=“range”] { accent-color: var(–accent); width: 80px; }

.viz-area { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 24px 16px; overflow-y: auto; gap: 24px; flex-wrap: wrap; }
.canvas-wrapper { display: flex; flex-direction: column; align-items: center; gap: 12px; }
.canvas-wrapper .canvas-label { font-size: 11px; color: var(–text-dim); letter-spacing: .1em; text-transform: uppercase; }
canvas { border: 1px solid var(–border); border-radius: 4px; background: #1C2730; display: block; }

.legend, .summary-table { background: var(–bg-card); border: 1px solid var(–border); border-radius: 4px; padding: 14px 16px; min-width: 200px; max-width: 260px; }
.legend h3, .summary-table h3 { font-size: 11px; color: var(–accent); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px; border-bottom: 1px solid var(–border); padding-bottom: 6px; }
.legend-item { display: flex; align-items: center; gap: 10px; margin-bottom: 7px; font-size: 12px; color: var(–text); }
.legend-swatch { width: 18px; height: 18px; border-radius: 2px; flex-shrink: 0; border: 1px solid rgba(255,255,255,.15); }
.legend-item .dim { color: var(–text-dim); font-size: 11px; margin-left: auto; }
.summary-row { display: flex; justify-content: space-between; gap: 16px; margin-bottom: 6px; font-size: 12px; }
.summary-row .key { color: var(–text-dim); }
.summary-row .val { color: var(–text); text-align: right; }

.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: var(–text-dim); font-size: 13px; padding: 60px 20px; text-align: center; width: 100%; }
.empty-state .icon { font-size: 48px; opacity: .4; }

.flag { font-size: 11px; padding: 4px 8px; border-radius: 3px; margin-top: 4px; display: inline-block; }
.flag.warn { background: rgba(230,184,64,.15); color: var(–yellow); border: 1px solid var(–yellow); }
.flag.ok   { background: rgba(76,175,130,.15); color: var(–green);  border: 1px solid var(–green); }
.flag.err  { background: rgba(201,64,64,.15);  color: var(–red);    border: 1px solid var(–red); }

.notes-area { border-top: 1px solid var(–border); padding: 12px 20px; background: var(–bg-deep); display: flex; gap: 12px; align-items: flex-start; flex-wrap: wrap; }
.notes-area textarea { flex: 1; min-width: 200px; background: var(–bg-card); border: 1px solid var(–border); color: var(–text); font-family: var(–mono); font-size: 12px; padding: 8px 10px; border-radius: 3px; resize: vertical; min-height: 60px; }
.notes-area textarea:focus { outline: none; border-color: var(–accent); }
.notes-area textarea::placeholder { color: var(–text-dim); }

@media (max-width:860px) { .workspace { grid-template-columns: 1fr; } .panel-right { min-height: 500px; } }
</style>

</head>
