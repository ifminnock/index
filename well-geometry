<!-- BOREHOLE & CASING -->
<div class="panel-section">
  <div class="panel-section-header" onclick="toggleSection('borehole')">Borehole &amp; Casing <span id="arrow-borehole">▼</span></div>
  <div class="panel-section-body" id="sec-borehole">

    <div class="component-row active">
      <div style="flex:1">
        <div class="component-label">Borehole <span class="sub">Drill bit / augered hole size</span></div>
        <div class="component-inputs visible">
          <div class="input-group">
            <label>Diameter (in)</label>
            <input type="number" id="borehole-dia" value="7" min="1" max="48" step="0.25" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Total Depth (ft)</label>
            <input type="number" id="borehole-depth" value="20" min="1" max="300" step="1" onchange="draw()">
          </div>
        </div>
      </div>
    </div>

    <div class="component-row" id="row-casing">
      <input type="checkbox" id="chk-casing" onchange="toggleComp('casing')">
      <div style="flex:1">
        <label class="component-label" for="chk-casing">Well Casing / Riser <span class="sub">PVC, ABS, or other pipe</span></label>
        <div class="component-inputs" id="inputs-casing">
          <div class="input-group">
            <label>OD (in)</label>
            <input type="number" id="casing-od" value="3.5" min="0.5" max="24" step="0.25" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Wall (in)</label>
            <input type="number" id="casing-wall" value="0.15" min="0.05" max="1" step="0.05" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Material</label>
            <select id="casing-mat" onchange="draw()">
              <option value="pvc">PVC</option>
              <option value="abs" selected>ABS</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="component-row" id="row-screen">
      <input type="checkbox" id="chk-screen" onchange="toggleComp('screen')">
      <div style="flex:1">
        <label class="component-label" for="chk-screen">Screen / Perforations <span class="sub">Slotted or perforated interval</span></label>
        <div class="component-inputs" id="inputs-screen">
          <div class="input-group">
            <label>Top Depth (ft)</label>
            <input type="number" id="screen-top" value="16" min="0" max="299" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Length (ft)</label>
            <input type="number" id="screen-len" value="4" min="0.5" max="100" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Type</label>
            <select id="screen-type" onchange="draw()">
              <option value="machine">Machine Slotted</option>
              <option value="hand">Hand Slotted</option>
              <option value="commercial">Commercial Screen</option>
            </select>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ANNULAR FILL -->
<div class="panel-section">
  <div class="panel-section-header" onclick="toggleSection('annular')">Annular Fill Zones <span id="arrow-annular">▼</span></div>
  <div class="panel-section-body" id="sec-annular">

    <div class="component-row" id="row-filterpack">
      <input type="checkbox" id="chk-filterpack" onchange="toggleComp('filterpack')">
      <div style="flex:1">
        <label class="component-label" for="chk-filterpack">Filter Pack / Gravel Pack <span class="sub">Sand or gravel around screen or perc interval</span></label>
        <div class="component-inputs" id="inputs-filterpack">
          <div class="input-group">
            <label>Top Depth (ft)</label>
            <input type="number" id="fp-top" value="14" min="0" max="299" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Bottom Depth (ft)</label>
            <input type="number" id="fp-bot" value="20" min="0.5" max="300" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Material</label>
            <select id="fp-mat" onchange="draw()">
              <option value="half-three-quarter" selected>½–¾" Gravel</option>
              <option value="pea">Pea Gravel (#8)</option>
              <option value="sand">Coarse Sand</option>
              <option value="chips">Gravel Chips</option>
              <option value="natural">Natural (cave-in)</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="component-row" id="row-bentonite">
      <input type="checkbox" id="chk-bentonite" onchange="toggleComp('bentonite')">
      <div style="flex:1">
        <label class="component-label" for="chk-bentonite">Bentonite Seal <span class="sub">Annular seal above filter pack</span></label>
        <div class="component-inputs" id="inputs-bentonite">
          <div class="input-group">
            <label>Top Depth (ft)</label>
            <input type="number" id="bent-top" value="12" min="0" max="299" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Bottom Depth (ft)</label>
            <input type="number" id="bent-bot" value="14" min="0.5" max="300" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Form</label>
            <select id="bent-form" onchange="draw()">
              <option value="chips" selected>⅜" Chips</option>
              <option value="pellets">Pellets</option>
              <option value="granular">Granular</option>
              <option value="slurry">Slurry</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="component-row" id="row-grout">
      <input type="checkbox" id="chk-grout" onchange="toggleComp('grout')">
      <div style="flex:1">
        <label class="component-label" for="chk-grout">Cement / Grout Seal <span class="sub">Surface seal or full annular grout</span></label>
        <div class="component-inputs" id="inputs-grout">
          <div class="input-group">
            <label>Top Depth (ft)</label>
            <input type="number" id="grout-top" value="0" min="-3" max="299" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Bottom Depth (ft)</label>
            <input type="number" id="grout-bot" value="10" min="0.5" max="300" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Mix</label>
            <select id="grout-mix" onchange="draw()">
              <option value="cement">Neat Cement</option>
              <option value="cement-bent">Cement-Bentonite</option>
              <option value="bent-slurry">Bentonite Slurry</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="component-row" id="row-cuttings">
      <input type="checkbox" id="chk-cuttings" onchange="toggleComp('cuttings')">
      <div style="flex:1">
        <label class="component-label" for="chk-cuttings">Auger Cuttings Backfill <span class="sub">Native cuttings returned to annulus</span></label>
        <div class="component-inputs" id="inputs-cuttings">
          <div class="input-group">
            <label>Top Depth (ft)</label>
            <input type="number" id="cut-top" value="0" min="0" max="299" step="0.5" onchange="draw()">
          </div>
          <div class="input-group">
            <label>Bottom Depth (ft)</label>
            <input type="number" id="cut-bot" value="12" min="0.5" max="300" step="0.5" onchange="draw()">
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

